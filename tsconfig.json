{
  "compilerOptions": {
    "lib": ["es2021"],
    "module": "commonjs",
    "target": "es2021",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "declaration": true,
    "rootDir": "src",
    "outDir": "lib",
    "importsNotUsedAsValues": "error",
    "baseUrl": "./src",
    "paths": {
      "under-the-sun": ["."]
    }
  },
  "include": ["src/**/*.ts", "magic-global.d.ts"]
}
